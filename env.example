# Copia este archivo como .env y completa los valores reales.
# El archivo .env NUNCA se sube a Git.

# --- JupyterLab ---
JUPYTER_TOKEN=coloca_aqui_un_token_seguro

# --- n8n ---
N8N_HOST=tu-dominio.ejemplo.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://tu-dominio.ejemplo.com/
N8N_PORT=5678
N8N_SECURE_COOKIE=true
N8N_RESTRICT_FILE_ACCESS_TO=/shared

# --- Python Worker (Gemini) ---
GEMINI_API_KEY=coloca_aqui_tu_api_key_de_gemini
